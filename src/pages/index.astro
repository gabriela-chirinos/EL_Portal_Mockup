---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import MenuSection from '../components/MenuSection.astro';
import WordsSection from '../components/WordsSection.astro';
import TruckSection from '../components/TruckSection.astro';
import SignatureDishes from '../components/SignatureDishes.astro';
import PanDulceFeature from '../components/PanDulceFeature.astro';
import StorySection from '../components/StorySection.astro';
import Reviews from '../components/Reviews.astro';
import FindTruck from '../components/FindTruck.astro';
import SocialSection from '../components/SocialSection.astro';
import HoursLocation from '../components/HoursLocation.astro';
import OrderCTA from '../components/OrderCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="El Portal Yelm — Taqueria & Carniceria">
  <Nav />
  <Hero />
  <Marquee />
  <MenuSection />
  <WordsSection />
  <TruckSection />
  <SignatureDishes />
  <PanDulceFeature />
  <StorySection />
  <Reviews />
  <FindTruck />
  <SocialSection />
  <HoursLocation />
  <OrderCTA />
  <Footer />

  <!-- Sticky bottom catering CTA -->
  <div id="sticky-catering-bar" aria-label="Catering inquiry shortcut">
    <span class="scb-label">Need catering services?</span>
    <a href="#catering" class="scb-btn" id="scb-link">Book Now →</a>
    <button class="scb-close" id="scb-close" type="button" aria-label="Dismiss">×</button>
  </div>
</Layout>

<script>
  const bar   = document.getElementById('sticky-catering-bar');
  const close = document.getElementById('scb-close');
  const link  = document.getElementById('scb-link');

  // Track both states; bar shows only when hero is gone AND catering is not visible
  let heroVisible     = true;  // start true — page loads at top
  let cateringVisible = false;

  function syncBar(): void {
    if (!bar || bar.classList.contains('scb-dismissed')) return;
    const shouldShow = !heroVisible && !cateringVisible;
    bar.classList.toggle('scb-hidden', !shouldShow);
  }

  // Start hidden (hero is visible on load)
  bar?.classList.add('scb-hidden');

  const hero     = document.getElementById('home');
  const catering = document.getElementById('catering');

  if (hero) {
    new IntersectionObserver(
      ([entry]) => { heroVisible = entry.isIntersecting; syncBar(); },
      { threshold: 0.1 }
    ).observe(hero);
  }

  if (catering) {
    new IntersectionObserver(
      ([entry]) => { cateringVisible = entry.isIntersecting; syncBar(); },
      { threshold: 0.15 }
    ).observe(catering);
  }

  // Dismiss permanently for this session
  close?.addEventListener('click', () => {
    bar?.classList.add('scb-dismissed', 'scb-hidden');
  });

  // Scroll to catering; on mobile also trigger the wizard
  link?.addEventListener('click', (e) => {
    e.preventDefault();
    const section = document.getElementById('catering');
    if (!section) return;
    section.scrollIntoView({ behavior: 'smooth' });
    if (window.innerWidth <= 768) {
      setTimeout(() => document.getElementById('cmi-start')?.click(), 600);
    }
  });
</script>

---
---
<nav id="main-nav">
  <a href="/" class="nav-logo-img">
    <img src={`${import.meta.env.BASE_URL}assets/svgLogo.svg`} alt="El Portal Yelm" height="40" />
  </a>
  <ul class="nav-links">
    <li><a href="#menu">Menu</a></li>
    <li><a href="#story">Our Story</a></li>
    <li><a href="#hours">Hours</a></li>
    <li><a href="#location">Find Us</a></li>
  </ul>
  <button class="nav-cta" onclick="document.getElementById('order').scrollIntoView()">Order Now</button>
</nav>

<!-- Hamburger toggle — outside <nav> so its z-index beats the backdrop stacking context -->
<button
  class="nav-hamburger"
  id="nav-hamburger"
  type="button"
  aria-label="Open navigation"
  aria-expanded="false"
  aria-controls="nav-mobile-menu"
>
  <span class="ham-bar"></span>
  <span class="ham-bar"></span>
  <span class="ham-bar"></span>
</button>

<!-- Mobile full-screen overlay -->
<div
  class="nav-mobile-overlay"
  id="nav-mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
  data-state="closed"
>
  <!-- Ghost wordmark decoration -->
  <div class="nmo-ghost" aria-hidden="true">EL PORTAL</div>

  <div class="nmo-inner">
    <div class="nmo-header">
      <a href="/" class="nmo-logo-link" id="nmo-logo">
        <img src={`${import.meta.env.BASE_URL}assets/svgLogo.svg`} alt="El Portal Yelm" height="36" />
      </a>
      <button class="nmo-close" id="nmo-close" type="button" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
      </button>
    </div>

    <nav class="nmo-nav" aria-label="Primary navigation">
      <a href="#menu"     class="nmo-link" data-delay="0">
        <span class="nmo-num">01</span><span class="nmo-label">Menu</span>
        <span class="nmo-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#story"    class="nmo-link" data-delay="1">
        <span class="nmo-num">02</span><span class="nmo-label">Our Story</span>
        <span class="nmo-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#hours"    class="nmo-link" data-delay="2">
        <span class="nmo-num">03</span><span class="nmo-label">Hours</span>
        <span class="nmo-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#location" class="nmo-link" data-delay="3">
        <span class="nmo-num">04</span><span class="nmo-label">Find Us</span>
        <span class="nmo-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#catering" class="nmo-link" data-delay="4">
        <span class="nmo-num">05</span><span class="nmo-label">Catering</span>
        <span class="nmo-arrow" aria-hidden="true">→</span>
      </a>
    </nav>

    <div class="nmo-footer">
      <button class="nmo-cta" id="nmo-order-btn" type="button">Order Now</button>
      <div class="nmo-contact">
        <a href="tel:+13609608405">(360) 960-8405</a>
        <span>·</span>
        <span>Yelm, WA</span>
      </div>
    </div>
  </div>
</div>

<!-- Backdrop -->
<div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var hamburger = document.getElementById('nav-hamburger');
    var overlay   = document.getElementById('nav-mobile-menu');
    var backdrop  = document.getElementById('nav-backdrop');
    var closeBtn  = document.getElementById('nmo-close');
    var orderBtn  = document.getElementById('nmo-order-btn');
    var links     = overlay ? overlay.querySelectorAll('.nmo-link') : [];

    var isOpen = false;

    function openMenu() {
      isOpen = true;
      if (overlay)  overlay.setAttribute('data-state', 'open');
      if (backdrop) backdrop.classList.add('is-visible');
      if (hamburger) {
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Close navigation');
        hamburger.classList.add('is-active');
      }
      document.body.style.overflow = 'hidden';
      setTimeout(function () {
        var first = overlay && overlay.querySelector('.nmo-link');
        if (first) first.focus();
      }, 320);
    }

    function closeMenu() {
      isOpen = false;
      if (overlay)  overlay.setAttribute('data-state', 'closed');
      if (backdrop) backdrop.classList.remove('is-visible');
      if (hamburger) {
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open navigation');
        hamburger.classList.remove('is-active');
        hamburger.focus();
      }
      document.body.style.overflow = '';
    }

    if (hamburger) {
      hamburger.addEventListener('click', function () {
        if (isOpen) closeMenu(); else openMenu();
      });
    }
    if (closeBtn)  closeBtn.addEventListener('click', closeMenu);
    if (backdrop)  backdrop.addEventListener('click', closeMenu);

    links.forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    if (orderBtn) {
      orderBtn.addEventListener('click', function () {
        closeMenu();
        setTimeout(function () {
          var el = document.getElementById('order');
          if (el) el.scrollIntoView({ behavior: 'smooth' });
        }, 280);
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    if (overlay) {
      overlay.addEventListener('keydown', function (e) {
        if (e.key !== 'Tab') return;
        var focusable = Array.from(overlay.querySelectorAll('a, button, [tabindex="0"]'))
          .filter(function (el) { return !el.hasAttribute('disabled'); });
        if (!focusable.length) return;
        var first = focusable[0];
        var last  = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { last.focus(); e.preventDefault(); }
        } else {
          if (document.activeElement === last)  { first.focus(); e.preventDefault(); }
        }
      });
    }
  });
</script>
